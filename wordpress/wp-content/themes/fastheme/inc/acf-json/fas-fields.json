[
    {
        "key": "group_fas_homepage",
        "title": "Configuración Homepage",
        "fields": [
            {
                "key": "field_nosotros_title",
                "label": "Título - Nuestra razón de ser",
                "name": "nosotros_title",
                "type": "text"
            },
            {
                "key": "field_nosotros_text",
                "label": "Texto - Nuestra razón de ser",
                "name": "nosotros_text",
                "type": "textarea"
            },
            {
                "key": "field_nosotros_link",
                "label": "Link a quiénes somos",
                "name": "nosotros_link",
                "type": "text"
            }
        ],
        "location": [
            [
                {
                    "param": "post_type",
                    "operator": "==",
                    "value": "page"
                }
            ]
        ],
        "menu_order": 0,
        "position": "normal",
        "style": "default",
        "label_placement": "top",
        "instruction_placement": "label",
        "hide_on_screen": ""
    },
    {
        "key": "group_fas_programa",
        "title": "Configuración de Programa",
        "fields": [
            {
                "key": "field_programa_descripcion",
                "label": "Descripción del Programa",
                "name": "programa_descripcion",
                "type": "wysiwyg",
                "toolbar": "full"
            },
            {
                "key": "field_programa_imagen",
                "label": "Imagen Principal",
                "name": "programa_imagen",
                "type": "image",
                "return_format": "url",
                "preview_size": "medium"
            },
            {
                "key": "field_programa_tipo",
                "label": "Tipo de Programa",
                "name": "programa_tipo",
                "type": "taxonomy",
                "taxonomy": "tipo_programa",
                "field_type": "select",
                "allow_null": 1
            },
            {
                "key": "field_programa_proyectos",
                "label": "Proyectos Relacionados",
                "name": "programa_proyectos",
                "type": "relationship",
                "post_type": ["proyecto"],
                "filters": ["search", "taxonomy"],
                "elements": "thumb"
            }
        ],
        "location": [
            [
                {
                    "param": "post_type",
                    "operator": "==",
                    "value": "page"
                }
            ]
        ],
        "menu_order": 0,
        "position": "normal",
        "style": "default",
        "label_placement": "top",
        "instruction_placement": "label",
        "hide_on_screen": ""
    },
