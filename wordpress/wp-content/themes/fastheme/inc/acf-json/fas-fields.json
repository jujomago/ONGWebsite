    {
        "key": "group_fas_slide",
        "title": "Datos del Slide",
        "fields": [
            {
                "key": "field_slide_label",
                "label": "Etiqueta superior",
                "name": "slide_label",
                "type": "text",
                "instructions": "Texto pequeño que aparece arriba del título (ej: Fundación Alimentando Sonrisas)"
            },
            {
                "key": "field_slide_title",
                "label": "Título (soporta HTML)",
                "name": "slide_title",
                "type": "textarea",
                "rows": 2,
                "instructions": "Título del slide. Puedes usar HTML. Ej: Ayudamos a niños a tener un <span class='italic text-fas-accent'>mejor futuro</span>"
            },
            {
                "key": "field_slide_subtitle",
                "label": "Subtítulo",
                "name": "slide_subtitle",
                "type": "textarea",
                "rows": 2,
                "instructions": "Texto descriptivo debajo del título"
            }
        ],
        "location": [
            [
                {
                    "param": "post_type",
                    "operator": "==",
                    "value": "slide"
